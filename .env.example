# Google OAuth credentials (required)
# Create at https://console.cloud.google.com/apis/credentials
# Enable the Gmail API and Google Calendar API
# Set authorized redirect URI to: http://localhost
MAIN_VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
MAIN_VITE_GOOGLE_CLIENT_SECRET=your-client-secret

# Z.AI API key (required for email analysis and drafts)
# Get one at https://open.z.ai/
ZAI_API_KEY=your-zai-api-key


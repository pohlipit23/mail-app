{
  "name": "exo",
  "version": "0.0.0",
  "license": "BSL-1.1",
  "description": "Automated email draft generator using Claude AI and Gmail",
  "repository": {
    "type": "git",
    "url": "https://github.com/ankitvgupta/mail-app.git"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "workspaces": [
    "src/extensions-private/*"
  ],
  "scripts": {
    "dev": "npm run ensure-native && npm run build:worker && electron-vite dev",
    "dev:demo": "npm run ensure-native && EXO_DEMO_MODE=true electron-vite dev",
    "build:worker": "vite build --config vite.worker.config.ts",
    "build": "electron-vite build && npm run build:worker",
    "preview": "electron-vite preview",
    "ensure-native": "./scripts/ensure-native-modules.sh",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release": "npm run build && electron-builder --publish always",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "test": "./scripts/run-tests.sh",
    "test:unit": "./scripts/run-tests.sh unit",
    "test:e2e": "./scripts/run-tests.sh e2e",
    "test:integration": "./scripts/run-tests.sh integration",
    "test:problematic": "playwright test --project=problematic",
    "test:bench": "playwright test --project=benchmark",
    "test:headed": "playwright test --headed",
    "test:quick": "playwright test --project=unit --project=integration",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "eval": "npx tsx tests/evals/runner.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.37",
    "@anthropic-ai/sdk": "^0.71.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@floating-ui/dom": "^1.7.6",
    "@googleapis/calendar": "^14.2.0",
    "@googleapis/gmail": "^16.1.1",
    "@googleapis/oauth2": "^5.0.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-virtual": "^3.13.21",
    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-text-align": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@tiptap/suggestion": "^3.20.0",
    "@types/dompurify": "^3.0.5",
    "algoliasearch": "^5.50.0",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.3.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.7.3",
    "mime-types": "^3.0.2",
    "nodemailer": "^8.0.4",
    "openai": "^6.34.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "posthog-js": "^1.359.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "semver": "^7.7.4",
    "tippy.js": "^6.3.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/forms": "^0.5.9",
    "@types/better-sqlite3": "^7.6.12",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^7.0.5",
    "@types/pino": "^7.0.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^39.8.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "msw": "^2.12.10",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.0.5"
  },
  "build": {
    "appId": "com.exo",
    "productName": "Exo",
    "artifactName": "${name}-${version}-${arch}-${os}.${ext}",
    "protocols": [
      {
        "name": "Email",
        "schemes": [
          "mailto"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "category": "Network;Email;"
    },
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/claude-agent-sdk/**"
    ],
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "ankitvgupta",
      "repo": "mail-app",
      "private": true
    },
    "directories": {
      "output": "release"
    }
  }
}
